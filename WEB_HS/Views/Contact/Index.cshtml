@{
    ViewData["Title"] = "Contact";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            <h1 class="mb-4 text-center">
                <i class="bi bi-envelope-heart"></i> @ViewData["Title"]
            </h1>

            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body text-center">
                            <i class="bi bi-question-circle display-1 text-primary mb-3"></i>
                            <h3>Une question ?</h3>
                            <p class="text-muted">
                                Vous avez des questions sur le fonctionnement de la plateforme ?
                                Nous sommes là pour vous aider.
                            </p>
                        </div>
                    </div>
                </div>

                <div class="col-md-6 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body text-center">
                            <i class="bi bi-lightbulb display-1 text-warning mb-3"></i>
                            <h3>Une suggestion ?</h3>
                            <p class="text-muted">
                                Vous avez des idées pour améliorer PortfolioHub ?
                                Partagez-les avec nous !
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card shadow-lg">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-send"></i> Envoyez-nous un message
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form method="post" asp-controller="Contact" asp-action="Index">
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Votre nom *</label>
                                <input type="text" name="NomAuteur" class="form-control" required placeholder="Votre nom complet" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold">Votre email *</label>
                                <input type="email" name="EmailAuteur" class="form-control" required placeholder="votre@email.com" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Votre message *</label>
                            <textarea name="Contenu" class="form-control" rows="5" required placeholder="Décrivez votre demande..."></textarea>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-send-fill"></i> Envoyer le message
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="mt-5">
                <h3 class="mb-4">
                    <i class="bi bi-info-circle"></i> Informations complémentaires
                </h3>
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5><i class="bi bi-clock"></i> Temps de réponse</h5>
                                <p class="mb-0">
                                    Nous nous engageons à répondre à tous les messages
                                    dans un délai de 48 heures ouvrées.
                                </p>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h5><i class="bi bi-shield-check"></i> Confidentialité</h5>
                                <p class="mb-0">
                                    Vos informations ne seront pas partagées avec des tiers
                                    et seront traitées de manière confidentielle.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>