@model IEnumerable<WEB_HS.Entities.Entreprise>

@{
    ViewData["Title"] = "Liste des Entreprises";
}

<div class="container mt-4">
    <h1 class="mb-4"><i class="bi bi-building"></i> Entreprise</h1>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="card-title text-primary">@item.Nom</h5>
                        <p class="text-muted small">
                            <i class="bi bi-calendar"></i> Partenaire depuis : @item.DateCreation.ToShortDateString()
                        </p>
                    </div>
                </div>
            </div>
        }
    </div>
</div>