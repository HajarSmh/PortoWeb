@model WEB_HS.Entities.Projet
@{
    ViewData["Title"] = "Supprimer le projet";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle"></i> @ViewData["Title"]
                    </h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <h5 class="alert-heading">
                            <i class="bi bi-exclamation-diamond"></i> Attention !
                        </h5>
                        <p class="mb-0">
                            Vous êtes sur le point de supprimer définitivement ce projet.
                            Cette action est irréversible.
                        </p>
                    </div>

                    <!-- Détails du projet -->
                    <div class="card mb-4">
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <img src="@Model.ImageUrl" class="card-img-top"
                                 alt="@Model.Titre" style="max-height: 200px; object-fit: cover;">
                        }
                        <div class="card-body">
                            <h5 class="card-title">@Model.Titre</h5>
                            <p class="card-text">@Model.Description</p>

                            <div class="mb-3">
                                <strong>Technologies :</strong>
                                <p class="text-muted">@Model.Technologies</p>
                            </div>

                            <div class="row">
                                <div class="col-6">
                                    <small class="text-muted">
                                        <i class="bi bi-calendar"></i>
                                        @Model.DateCreation.ToString("dd/MM/yyyy")
                                    </small>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.LienDemo))
                                {
                                    <div class="col-6 text-end">
                                        <a href="@Model.LienDemo" target="_blank"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> Voir la démo
                                        </a>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Confirmation -->
                    <div class="alert alert-warning">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   id="confirmDelete" required>
                            <label class="form-check-label fw-bold" for="confirmDelete">
                                Je confirme vouloir supprimer ce projet définitivement
                            </label>
                        </div>
                    </div>

                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="Index" class="btn btn-outline-secondary me-md-2">
                                <i class="bi bi-arrow-left"></i> Annuler
                            </a>
                            <button type="submit" class="btn btn-danger" id="deleteButton" disabled>
                                <i class="bi bi-trash"></i> Supprimer définitivement
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <!-- Alternatives -->
            <div class="card mt-3">
                <div class="card-body">
                    <h6><i class="bi bi-lightbulb"></i> Alternatives à la suppression</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <a asp-action="Edit" asp-route-id="@Model.Id"
                               class="btn btn-outline-warning w-100 mb-2">
                                <i class="bi bi-pencil"></i> Modifier à la place
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="@Url.Action("Details", "Profil", new { id = Model.PersonneId })"
                               class="btn btn-outline-primary w-100">
                                <i class="bi bi-eye"></i> Voir sur le profil
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Activer le bouton uniquement si confirmé
        document.getElementById('confirmDelete').addEventListener('change', function() {
            document.getElementById('deleteButton').disabled = !this.checked;
        });

        // Confirmation supplémentaire
        document.querySelector('form').addEventListener('submit', function(e) {
            if (!confirm('Êtes-vous ABSOLUMENT sûr ? Cette action ne peut pas être annulée.')) {
                e.preventDefault();
            }
        });
    </script>
}