@model List<WEB_HS.Entities.Projet>
@{
    ViewData["Title"] = "Mes Projets";
    var userId = Context.Session.GetInt32("UserId");
}

<div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>
            <i class="bi bi-briefcase"></i> @ViewData["Title"]
        </h1>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Nouveau projet
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-folder2-open display-1 text-muted mb-3"></i>
            <h3>Aucun projet pour le moment</h3>
            <p class="lead text-muted mb-4">
                Ajoutez vos projets pour montrer votre expérience et vos réalisations.
            </p>
            <a asp-action="Create" class="btn btn-primary btn-lg">
                <i class="bi bi-plus-circle"></i> Ajouter mon premier projet
            </a>
        </div>
    }
    else
    {
        <!-- Vue Grille -->
        <div class="row" id="gridView">
            @foreach (var projet in Model.OrderByDescending(p => p.DateCreation))
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm card-hover">
                        <!-- Image du projet -->
                        <div class="position-relative">
                            <img src="@(string.IsNullOrEmpty(projet.ImageUrl) ? "/images/project-default.jpg" : projet.ImageUrl)"
                                 class="card-img-top"
                                 alt="@projet.Titre"
                                 style="height: 200px; object-fit: cover;">
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-success">@projet.DateCreation.ToString("MMM yyyy")</span>
                            </div>
                        </div>

                        <div class="card-body">
                            <h5 class="card-title">@projet.Titre</h5>
                            <p class="card-text text-truncate-3" style="max-height: 60px; overflow: hidden;">
                                @projet.Description
                            </p>

                            <!-- Technologies -->
                            @if (!string.IsNullOrEmpty(projet.Technologies))
                            {
                                <div class="mb-3">
                                    @foreach (var tech in projet.Technologies.Split(',').Take(3))
                                    {
                                        <span class="badge bg-info me-1 mb-1">@tech.Trim()</span>
                                    }
                                    @if (projet.Technologies.Split(',').Length > 3)
                                    {
                                        <span class="badge bg-secondary">+@(projet.Technologies.Split(',').Length - 3)</span>
                                    }
                                </div>
                            }

                            <!-- Liens -->
                            <div class="btn-group w-100" role="group">
                                @if (!string.IsNullOrEmpty(projet.LienDemo))
                                {
                                    <a href="@projet.LienDemo" target="_blank"
                                       class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-eye"></i> Demo
                                    </a>
                                }
                                @if (!string.IsNullOrEmpty(projet.LienSource))
                                {
                                    <a href="@projet.LienSource" target="_blank"
                                       class="btn btn-outline-dark btn-sm">
                                        <i class="bi bi-github"></i> Code
                                    </a>
                                }
                            </div>
                        </div>

                        <div class="card-footer bg-transparent">
                            <div class="d-flex justify-content-between">
                                <a asp-action="Edit" asp-route-id="@projet.Id"
                                   class="btn btn-outline-warning btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@projet.Id"
                                   class="btn btn-outline-danger btn-sm">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Vue Tableau (alternative) -->
        <div class="d-none" id="tableView">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>Projet</th>
                            <th>Description</th>
                            <th>Technologies</th>
                            <th>Date</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var projet in Model.OrderByDescending(p => p.DateCreation))
                        {
                            <tr>
                                <td>
                                    <strong>@projet.Titre</strong>
                                </td>
                                <td>
                                    <div style="max-width: 300px;">
                                        @projet.Description
                                    </div>
                                </td>
                                <td>
                                    <div style="max-width: 200px;">
                                        @projet.Technologies
                                    </div>
                                </td>
                                <td>@projet.DateCreation.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="Edit" asp-route-id="@projet.Id"
                                           class="btn btn-outline-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@projet.Id"
                                           class="btn btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Contrôles de vue -->
        <div class="d-flex justify-content-between align-items-center mt-4">
            <div>
                <button class="btn btn-outline-secondary btn-sm me-2" onclick="showGridView()">
                    <i class="bi bi-grid-3x3-gap"></i> Grille
                </button>
                <button class="btn btn-outline-secondary btn-sm" onclick="showTableView()">
                    <i class="bi bi-list"></i> Liste
                </button>
            </div>

            <!-- Statistiques -->
            <div class="text-end">
                <small class="text-muted">
                    <i class="bi bi-folder"></i> @Model.Count projets |
                    <i class="bi bi-calendar"></i> Dernier: @Model.Max(p => p.DateCreation).ToString("dd/MM/yyyy")
                </small>
            </div>
        </div>
    }

    <div class="mt-4">
        <a href="/Profil/Details/@userId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Retour à mon profil
        </a>
    </div>
</div>

@section Scripts {
    <script>
        function showGridView() {
            document.getElementById('gridView').classList.remove('d-none');
            document.getElementById('tableView').classList.add('d-none');
        }

        function showTableView() {
            document.getElementById('gridView').classList.add('d-none');
            document.getElementById('tableView').classList.remove('d-none');
        }

        // Par défaut, afficher la vue grille
        document.addEventListener('DOMContentLoaded', function() {
            showGridView();
        });
    </script>
}